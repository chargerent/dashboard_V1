#!/bin/bash
# Auto-increment dashboard version on every commit

VERSION_FILE="src/version.js"

if [ ! -f "$VERSION_FILE" ]; then
  echo "Version file not found: $VERSION_FILE"
  exit 1
fi

CURRENT=$(grep -oE "[0-9]+\.[0-9]+" "$VERSION_FILE" | head -1)

if [ -z "$CURRENT" ]; then
  echo "Could not parse version from $VERSION_FILE"
  exit 1
fi

MAJOR=$(echo "$CURRENT" | cut -d. -f1)
MINOR=$(echo "$CURRENT" | cut -d. -f2)
NEW_MINOR=$((MINOR + 1))
NEW_VERSION="${MAJOR}.${NEW_MINOR}"

sed -i '' "s/VERSION = '${CURRENT}'/VERSION = '${NEW_VERSION}'/" "$VERSION_FILE"

git add "$VERSION_FILE"

echo "Dashboard version bumped: ${CURRENT} → ${NEW_VERSION}"
